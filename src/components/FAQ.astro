---
interface FaqItem {
  q: string;
  a: string;
}

const defaults: readonly FaqItem[] = [
  {
    q: "Do I not need a team?",
    a: "At seed to Series A you do not have a team-shaped problem yet. You have a senior-decision-shaped problem. One operator who has done this work before will out-ship a five-person agency on this scope. When the work genuinely needs a team, the next engagement is helping you hire one.",
  },
  {
    q: "Do you only work in Azure?",
    a: "Yes. Azure is where the depth is, and the depth is what you are paying for. We integrate cleanly with Vercel, Cloudflare, Neon and Supabase where it makes sense. If AWS or GCP is the right answer for your workload, we will tell you and point you to a specialist who delivers there.",
  },
  {
    q: "What about Microsoft Founders Hub credits?",
    a: "We work with founders to apply for Founders Hub credits, deploy onto them sensibly, and stretch them across the runway they are meant to cover. The Cost Management Rescue package, BSV-PKG-06, is the operational version of that work.",
  },
  {
    q: "How does pricing work?",
    a: "Fixed price for every package, written into the SOW before work starts. The retainer is monthly with a 30-day notice after the initial three months. No success fees, no commission on Azure spend — that would create the wrong incentives.",
  },
  {
    q: "Can you sign our MSA, NDA or DPA?",
    a: "Yes. We operate as a UK limited company with professional indemnity and cyber insurance, registered with the ICO as a data controller. NDAs turned around the same day. MSA review usually within two business days.",
  },
  {
    q: "What do you not do?",
    a: "Front-end product work. Marketing site builds beyond our own. Generic transformation programmes. Multi-year managed-service contracts. AWS or GCP. Anything outside the seed-to-Series-A ICP where a different shape of provider is the right answer.",
  },
  {
    q: "We already have a developer on the team. Why do we need BSV?",
    a: "Your developer is there to build your product — not to design landing zones, harden your security posture, or optimise your Azure spend. These are specialist disciplines that take years to develop. Bringing in BSV means your engineers stay focused on shipping features while we handle the infrastructure layer that supports everything they build. We hand everything back documented, codified in Terraform, and ready for your team to maintain."
  },
  {
    q: "We're pre-revenue. Can we afford this?",
    a: "The better question is whether you can afford not to. An unoptimised Azure environment can burn through £150,000 of Founders Hub credits or create a huge bill in weeks. A misconfigured tenant can fail a security audit and cost you a contract or a funding round. BSV packages are fixed-price, one-off engagements — not retainers that drain your runway indefinitely. We also offer a 20% discount on a first package for pre-revenue startups. The Startup Launchpad starting at £4,500 is less than two weeks of a mid-level cloud engineer's salary."
  },
  {
    q: "How is BSV different from hiring a freelancer on Upwork or elsewhere?",
    a: "A freelancer quotes you an hourly rate and you carry the risk of scope creep, variable quality, and no accountability for the outcome. BSV sells fixed-scope, outcome-defined packages with defined deliverables and delivery timelines. You know exactly what you're getting and what it costs before we start. Every engagement is delivered by a SC-cleared senior architect with 10+ years in Azure — not a generalist who also does web hosting."
  },
  {
    q: "We're going through Series A due diligence. Is it too late to fix our Azure setup?",
    a: "Rarely. The Well-Architected Review and Roadmap gives you a clear picture of where you stand in seven business days. From there, we can prioritise the findings that matter most to a technical due diligence team — security posture, cost governance, architecture defensibility — and address them before your next investor conversation. Starting late is not ideal, but it is far better than walking into due diligence without knowing what a technical reviewer will find."
  },
  {
    q: "Do you offer ongoing support after a package is delivered?",
    a: "Every package includes a handover documentation pack and a structured async Q&A window so your team can hit the ground running. If you want ongoing strategic cover after that, the Fractional CTO Retainer is designed exactly for that — up to two days of hands-on technical work per month, async availability, and a monthly strategy call with the founder. It is a rolling monthly engagement after a three-month minimum, with 30 days notice to exit."
  },
];

interface Props {
  items?: readonly FaqItem[];
  /** Open the first item by default. */
  openFirst?: boolean;
}

const { items = defaults, openFirst = false } = Astro.props;
---

<section
  id="faq"
  aria-labelledby="faq-heading"
  class="border-t border-[color:var(--color-rule)]"
>
  <div class="container-page py-14 sm:py-20 md:py-28 grid gap-8 lg:gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <p class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">
        faq
      </p>
      <h2
        id="faq-heading"
        class="mt-3 text-xl sm:text-2xl md:text-3xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] leading-tight text-balance"
      >
        Questions founders actually ask
      </h2>
      <p class="mt-4 text-[color:var(--color-muted)] max-w-sm">
        If yours is not here, ask it on the call. We answer the same way we work — directly.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-flex items-center gap-2 mono text-sm text-[color:var(--color-muted)] hover:text-[color:var(--color-accent)] transition-colors"
      >
        ask it on a call →
      </a>
    </div>

    <div class="lg:col-span-8">
      <ul class="border-y border-[color:var(--color-rule)] divide-y divide-[color:var(--color-rule)]">
        {items.map((f, i) => (
          <li>
            <details class="group bsv-faq-item" open={openFirst && i === 0}>
              <summary class="flex items-start justify-between gap-3 sm:gap-6 py-4 sm:py-5 cursor-pointer list-none">
                <span class="flex items-baseline gap-3 sm:gap-4 pr-2 sm:pr-4">
                  <span class="mono text-xs text-[color:var(--color-muted)] tabular-nums shrink-0 pt-1">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="text-[15px] sm:text-base md:text-lg font-medium text-[color:var(--color-fg-strong)] leading-snug text-pretty">
                    {f.q}
                  </span>
                </span>
                <span
                  aria-hidden="true"
                  class="bsv-faq-icon mt-1 shrink-0 mono text-[color:var(--color-muted)] group-open:text-[color:var(--color-accent)] transition-transform duration-200"
                >
                  +
                </span>
              </summary>
              <div class="pb-5 sm:pb-6 pl-8 sm:pl-10 pr-2 sm:pr-4 text-[color:var(--color-fg)] max-w-[62ch] leading-relaxed text-pretty">
                {f.a}
              </div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  /* Remove the default disclosure triangle in WebKit */
  .bsv-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .bsv-faq-item[open] .bsv-faq-icon {
    transform: rotate(45deg);
  }

  .bsv-faq-item summary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 2px;
  }
</style>

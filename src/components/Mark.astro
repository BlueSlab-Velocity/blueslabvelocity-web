---
import { Image } from "astro:assets";
import logo from "~/assets/bsv-logo.png";

interface Props {
  /** Title-only mark, no icon */
  variant?: "full" | "wordmark";
  class?: string;
}
const { variant = "full", class: className = "" } = Astro.props;
---

<a
  href="/"
  class:list={["inline-flex items-center gap-2.5 group", className]}
  aria-label="Blue Slab Velocity, home"
  transition:name="bsv-mark"
>
  {variant === "full" && (
    <Image
      src={logo}
      alt=""
      width={120}
      height={65}
      densities={[1, 2]}
      loading="eager"
      decoding="sync"
      class="shrink-0 h-18 w-auto"
    />
  )}
  <span class="font-semibold tracking-tight text-[color:var(--color-fg-strong)]">
    Blue Slab <span class="text-[color:var(--color-accent)]">Velocity</span>
  </span>
</a>

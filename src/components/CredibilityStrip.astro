---
const certs = ["AZ-104", "AZ-305", "AZ-400", "CKA", "Terraform Associate", "FinOps Practitioner"] as const;
const sectors = ["FinTech", "HealthTech", "LegalTech", "PropTech", "EdTech", "B2B SaaS"] as const;
const geos = ["United Kingdom", "Western Europe", "Selected international"] as const;
---

<section
  aria-label="Credentials"
  class="border-y border-[color:var(--color-rule)] bg-[color:var(--color-bg-elev)]"
>
  <div class="container-page py-10 grid gap-8 md:grid-cols-3">
    <div>
      <p class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">certifications</p>
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {certs.map((c) => (
          <li class="mono text-xs px-2 py-1 border border-[color:var(--color-rule)] text-[color:var(--color-fg-strong)]">{c}</li>
        ))}
      </ul>
    </div>
    <div>
      <p class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">sectors served</p>
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {sectors.map((s) => (
          <li class="mono text-xs px-2 py-1 border border-[color:var(--color-rule)] text-[color:var(--color-fg)]">{s}</li>
        ))}
      </ul>
    </div>
    <div>
      <p class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">geography</p>
      <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-fg)]">
        {geos.map((g) => <li>{g}</li>)}
      </ul>
    </div>
  </div>
</section>

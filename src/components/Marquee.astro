---
const logos = [
  "Microsoft Azure","Microsoft Foundry", "Microsoft for Startups", "Azure Landing Zones", "Azure Governance", "Azure OpenAI", "Azure Kubernetes Service", "Bicep", "Terraform",
  "Entra ID", "Front Door", "Cosmos DB", "AI Agents", "Azure Functions", "Container Apps",
  "Defender for Cloud", "Application Gateway", "Service Bus", "Event Grid", "Azure App Services",
  "API Management", "Log Analytics", "Key Vault", "Private Link", "RAG", "Azure Container Registry",
];
const doubled = [...logos, ...logos];
---
<section aria-label="Stack" class="border-b border-[color:var(--color-rule)]">
  <div class="container-page py-4 sm:py-6 flex items-center gap-4 sm:gap-8">
    <span class="hidden md:inline shrink-0 mono text-[11px] uppercase tracking-[0.18em] text-[color:var(--color-muted)]">
      Stack&nbsp;·&nbsp;Battle-tested
    </span>
    <div class="relative flex-1 overflow-hidden no-scrollbar [mask-image:linear-gradient(to_right,transparent,black_6%,black_94%,transparent)]">
      <ul class="marquee-track flex w-max items-center gap-7 sm:gap-10 whitespace-nowrap mono text-[11px] sm:text-[12px] tracking-[0.06em] text-[color:var(--color-muted)]">
        {doubled.map((l) => (
          <li class="inline-flex items-center gap-3">
            <span class="h-1 w-1 rounded-full bg-[color:var(--color-rule)]"></span>
            {l}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

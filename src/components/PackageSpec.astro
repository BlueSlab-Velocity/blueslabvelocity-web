---
import type { Package } from "~/lib/packages";
import { formatGBP } from "~/lib/format";
import Annotation from "./Annotation.astro";

interface Props {
  pkg: Package;
}
const { pkg } = Astro.props;

const paymentLabel =
  pkg.paymentTerms === "monthly"
    ? "Monthly in advance"
    : "50% on signature, 50% on delivery";
---

<article>
  <header class="border-b border-[color:var(--color-rule)] pb-10">
    <div class="flex items-center justify-between gap-4">
      <Annotation label={`// ${pkg.code}`} />
      <span class="mono text-xs text-[color:var(--color-muted)]">
        {pkg.delivery}
      </span>
    </div>
    <h1 class="mt-4 text-3xl md:text-4xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] leading-tight">
      {pkg.name}
    </h1>
    <p class="mt-4 text-lg text-[color:var(--color-muted)] max-w-2xl">
      {pkg.tagline}
    </p>
  </header>

  <!-- Spec sheet header row -->
  <dl class="grid grid-cols-2 md:grid-cols-4 border-b border-[color:var(--color-rule)] divide-x divide-[color:var(--color-rule)]">
    <div class="px-4 md:px-6 py-5">
      <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Price</dt>
      <dd class="mono mt-2 text-base text-[color:var(--color-fg-strong)]">
        {formatGBP(pkg.price)}{pkg.priceSuffix ?? ""}
      </dd>
    </div>
    <div class="px-4 md:px-6 py-5">
      <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Delivery</dt>
      <dd class="mono mt-2 text-base text-[color:var(--color-fg-strong)]">{pkg.delivery}</dd>
    </div>
    <div class="px-4 md:px-6 py-5">
      <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Payment</dt>
      <dd class="mono mt-2 text-sm text-[color:var(--color-fg-strong)]">{paymentLabel}</dd>
    </div>
    <div class="px-4 md:px-6 py-5">
      <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">SKU</dt>
      <dd class="mono mt-2 text-base text-[color:var(--color-fg-strong)]">{pkg.code}</dd>
    </div>
  </dl>

  <!-- Body -->
  <div class="grid gap-12 lg:grid-cols-12 pt-12">
    <section class="lg:col-span-7 space-y-6">
      <div>
        <Annotation label="// scope" />
        <div class="mt-3 space-y-4 text-[1.0625rem] leading-relaxed">
          {pkg.scope.map((para) => <p>{para}</p>)}
        </div>
      </div>

      <div class="pt-6 border-t border-[color:var(--color-rule)]">
        <Annotation label="// deliverables" />
        <ul class="mt-4 divide-y divide-[color:var(--color-rule)] border-y border-[color:var(--color-rule)]">
          {pkg.deliverables.map((d, i) => (
            <li class="py-3 flex gap-4 items-baseline">
              <span class="mono text-xs text-[color:var(--color-muted)] w-10 shrink-0">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="text-[color:var(--color-fg)]">{d}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="pt-6">
        <Annotation label="// out of scope" />
        <ul class="mt-4 space-y-2 text-[color:var(--color-muted)]">
          {pkg.outOfScope.map((d) => (
            <li class="flex gap-3">
              <span aria-hidden="true" class="mono text-[color:var(--color-rule)]">×</span>
              <span>{d}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <aside class="lg:col-span-5 lg:col-start-9">
      <div class="border border-[color:var(--color-rule)] p-6 sticky top-6 bg-[color:var(--color-bg-elev)]">
        <Annotation label="// next step" />
        <p class="mt-3 text-[color:var(--color-fg-strong)] font-semibold">
          Discuss this package
        </p>
        <p class="mt-2 text-sm text-[color:var(--color-muted)]">
          A 30-minute call to confirm fit, scope and timing. No obligation.
        </p>
        <a
          href={`/contact?package=${pkg.code}`}
          class="mt-5 inline-flex items-center gap-2 px-4 py-2.5 bg-[color:var(--color-accent)] text-[color:var(--color-accent-fg)] mono text-sm font-medium hover:bg-[color:var(--color-accent-strong)] transition-colors w-full justify-center"
        >
          Enquire about {pkg.code}
          <span aria-hidden="true">→</span>
        </a>
        <dl class="mt-6 pt-6 border-t border-[color:var(--color-rule)] space-y-3 text-sm">
          <div class="flex justify-between">
            <dt class="text-[color:var(--color-muted)]">Engagement type</dt>
            <dd class="mono">{pkg.paymentTerms === "monthly" ? "Retainer" : "Fixed-scope"}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-[color:var(--color-muted)]">Lead time</dt>
            <dd class="mono">2–3 weeks</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-[color:var(--color-muted)]">Delivery model</dt>
            <dd class="mono">Remote, UK hours</dd>
          </div>
        </dl>
      </div>
    </aside>
  </div>
</article>

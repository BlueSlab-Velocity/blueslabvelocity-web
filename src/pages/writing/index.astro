---
import Page from "~/layouts/Page.astro";
import Annotation from "~/components/Annotation.astro";
import { formatDate, isoDate } from "~/lib/format";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<Page
  title="Writing"
  description="Notes from the practice. Azure architecture, founders credits, due diligence and the engineering decisions that survive a Series A."
  path="/writing"
>
  <section class="container-page pt-16 pb-12 border-b border-[color:var(--color-rule)]">
    <Annotation label="// writing · index" />
    <h1 class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] leading-[1.05] max-w-3xl">
      Notes from the practice
    </h1>
    <p class="mt-5 text-lg text-[color:var(--color-fg)] max-w-2xl leading-relaxed">
      Short essays on Azure architecture for startups. Written from inside the engagements, not from a marketing brief.
    </p>
  </section>

  <section class="container-page py-12">
    <ol class="border border-[color:var(--color-rule)] divide-y divide-[color:var(--color-rule)]">
      {posts.map((post, i) => (
        <li>
          <a
            href={`/writing/${post.id}`}
            class="group grid gap-4 md:grid-cols-12 md:gap-8 px-5 md:px-7 py-6 hover:bg-[color:var(--color-bg-elev)] transition-colors"
          >
            <div class="md:col-span-2 flex md:flex-col gap-3 md:gap-1 items-baseline">
              <span class="mono text-xs text-[color:var(--color-muted)]">
                {String(posts.length - i).padStart(3, "0")}
              </span>
              <time
                class="mono text-xs text-[color:var(--color-muted)]"
                datetime={isoDate(post.data.publishedAt)}
              >
                {formatDate(post.data.publishedAt)}
              </time>
            </div>
            <div class="md:col-span-10">
              <h2 class="text-lg md:text-xl font-semibold text-[color:var(--color-fg-strong)] tracking-tight group-hover:text-[color:var(--color-accent)] transition-colors">
                {post.data.title}
              </h2>
              <p class="mt-2 text-[color:var(--color-muted)] leading-relaxed">
                {post.data.description}
              </p>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <p class="mt-8 mono text-xs text-[color:var(--color-muted)]">
      // <a href="/rss.xml" class="hover:text-[color:var(--color-accent)]">rss feed</a>
    </p>
  </section>
</Page>

---
import Base from "~/layouts/Base.astro";
---

<Base
  title="Page not found"
  description="The page you were looking for does not exist."
  path="/404"
  noindex
>
  <main id="main" class="min-h-[80dvh] grid place-items-center">
    <div class="container-page text-center">
      <p class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">// 404</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]">
        Page not found
      </h1>
      <p class="mt-3 text-[color:var(--color-muted)]">
        The route you requested does not exist on this site.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 px-4 py-2.5 border border-[color:var(--color-rule)] hover:border-[color:var(--color-accent)] mono text-sm transition-colors"
      >
        ← Back to home
      </a>
    </div>
  </main>
</Base>

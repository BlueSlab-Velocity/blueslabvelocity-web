---
import Page from "~/layouts/Page.astro";
import Annotation from "~/components/Annotation.astro";
import { PACKAGES } from "~/lib/packages";
import { SITE } from "~/consts";

const presetPackage = Astro.url.searchParams.get("package") ?? "";
---

<Page
  title="Contact"
  description="Get in touch with Blue Slab Velocity. Book a 30-minute discovery call, send a direct email, or use the enquiry form."
  path="/contact"
>
  <section class="container-page pt-10 sm:pt-16 pb-10 sm:pb-12 border-b border-[color:var(--color-rule)]">
    <Annotation label="contact" />
    <h1 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] leading-[1.1] md:leading-[1.05] max-w-3xl text-balance">
      Three ways to reach us
    </h1>
    <p class="mt-5 text-base sm:text-lg text-[color:var(--color-fg)] max-w-2xl leading-relaxed text-pretty">
      Pick the channel that suits the conversation. We reply inside one business day.
    </p>
  </section>

  <section class="container-page py-12 grid gap-10 lg:grid-cols-12">
    <!-- Direct -->
    <div class="lg:col-span-5 space-y-8">
      <div class="border border-[color:var(--color-rule)] p-6">
        <Annotation label="01 · email" />
        <h2 class="mt-3 text-lg font-semibold text-[color:var(--color-fg-strong)]">
          Direct email
        </h2>
        <p class="mt-2 text-[color:var(--color-muted)] text-sm">
          The fastest path.
        </p>
        <a
          href={`mailto:${SITE.email}`}
          class="mono mt-4 inline-block text-[color:var(--color-fg-strong)] underline decoration-[color:var(--color-accent)] underline-offset-4"
        >
          {SITE.email}
        </a>
      </div>

      <div class="border border-[color:var(--color-rule)] p-6">
        <Annotation label="02 · book a call" />
        <h2 class="mt-3 text-lg font-semibold text-[color:var(--color-fg-strong)]">
          30-minute discovery call
        </h2>
        <p class="mt-2 text-[color:var(--color-muted)] text-sm">
          On the record, with the architect who delivers the work.
        </p>
        <!-- cal embed slot — intentionally not loading any third-party script in v1.
             To enable, add a Cal.com inline embed here and update the CSP frame-src
             and script-src in staticwebapp.config.json. -->
        <div
          class="mt-5 border border-dashed border-[color:var(--color-rule)] p-6 text-center"
          aria-label="Calendar embed placeholder"
        >
          <p class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">
            cal.com slot
          </p>
          <p class="mt-3 text-sm text-[color:var(--color-muted)]">
            Embedded scheduler ships in v1.1. In the meantime, email us and we will send a Cal link.
          </p>
        </div>
      </div>

      <div class="border border-[color:var(--color-rule)] p-6">
        <Annotation label="03 · what to send" />
        <h2 class="mt-3 text-lg font-semibold text-[color:var(--color-fg-strong)]">
          What to include in your first message
        </h2>
        <ul class="mt-3 space-y-1.5 text-sm text-[color:var(--color-fg)]">
          <li>· Stage and headcount</li>
          <li>· Where you are with Azure today</li>
          <li>· The outcome you need in the next 90 days</li>
        </ul>
      </div>
    </div>

    <!-- Form -->
    <div class="lg:col-span-7">
      <form
        action="/api/enquiry"
        method="POST"
        class="border border-[color:var(--color-rule)] p-6 md:p-8 space-y-5"
        aria-describedby="form-help"
      >
        <header>
          <Annotation label="enquiry form" />
          <h2 class="mt-3 text-lg font-semibold text-[color:var(--color-fg-strong)]">
            Send a brief
          </h2>
          <p id="form-help" class="mt-1 text-sm text-[color:var(--color-muted)]">
            Four fields. Plain text. No marketing follow-ups.
          </p>
        </header>

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="mt-2 w-full bg-[color:var(--color-bg)] border border-[color:var(--color-rule)] focus:border-[color:var(--color-accent)] outline-none px-3 py-2.5 text-[color:var(--color-fg-strong)]"
            />
          </label>
          <label class="block">
            <span class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Work email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="mt-2 w-full bg-[color:var(--color-bg)] border border-[color:var(--color-rule)] focus:border-[color:var(--color-accent)] outline-none px-3 py-2.5 text-[color:var(--color-fg-strong)]"
            />
          </label>
        </div>

        <label class="block">
          <span class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Package of interest</span>
          <select
            name="package"
            class="mt-2 w-full bg-[color:var(--color-bg)] border border-[color:var(--color-rule)] focus:border-[color:var(--color-accent)] outline-none px-3 py-2.5 text-[color:var(--color-fg-strong)]"
          >
            <option value="">Not sure yet</option>
            {PACKAGES.map((p) => (
              <option value={p.code} selected={presetPackage === p.code}>
                {p.code} · {p.name}
              </option>
            ))}
          </select>
        </label>

        <label class="block">
          <span class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">What do you need done?</span>
          <textarea
            name="message"
            required
            rows="6"
            minlength="20"
            maxlength="2000"
            class="mt-2 w-full bg-[color:var(--color-bg)] border border-[color:var(--color-rule)] focus:border-[color:var(--color-accent)] outline-none px-3 py-2.5 text-[color:var(--color-fg-strong)]"
          ></textarea>
        </label>

        <!-- Honeypot, hidden from humans, present for bots -->
        <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">
          <label>
            Leave this empty
            <input type="text" name="company_url" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <div class="pt-2 flex flex-col-reverse sm:flex-row sm:flex-wrap sm:items-center gap-4 sm:justify-between">
          <p class="mono text-xs text-[color:var(--color-muted)]">
            By submitting you accept our handling of this enquiry under UK GDPR.
          </p>
          <button
            type="submit"
            class="inline-flex justify-center items-center gap-2 px-4 py-2.5 bg-[color:var(--color-accent)] text-[color:var(--color-accent-fg)] mono text-sm font-medium hover:bg-[color:var(--color-accent-strong)] transition-colors"
          >
            Send enquiry →
          </button>
        </div>
      </form>
    </div>
  </section>
</Page>

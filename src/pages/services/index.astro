---
import Page from "~/layouts/Page.astro";
import Annotation from "~/components/Annotation.astro";
import { PACKAGES } from "~/lib/packages";
import { formatGBP } from "~/lib/format";
---

<Page
  title="Services"
  description="Six fixed-price Azure engagements for seed and Series A startups: landing zone, AI-ready platform, architecture review, fractional CTO retainer, security and compliance, and cost rescue."
  path="/services"
>
  <section class="container-page pt-10 sm:pt-16 pb-8 sm:pb-10 border-b border-[color:var(--color-rule)]">
    <Annotation label="services · index" />
    <h1 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] leading-[1.1] md:leading-[1.05] max-w-3xl text-balance">
      Six packages. Each one a spec sheet.
    </h1>
    <p class="mt-5 text-base sm:text-lg text-[color:var(--color-fg)] max-w-2xl leading-relaxed text-pretty">
      Fixed-price, time-boxed and outcome-defined. Pick the one that matches the work you need done. Combine them when it makes sense.
    </p>
  </section>

  <section class="container-page py-12">
    <ul class="border border-[color:var(--color-rule)] divide-y divide-[color:var(--color-rule)]">
      {PACKAGES.map((pkg) => (
        <li>
          <a
            href={`/services/${pkg.slug}`}
            class="group grid gap-4 md:grid-cols-12 md:gap-8 px-5 md:px-7 py-6 hover:bg-[color:var(--color-bg-elev)] transition-colors"
          >
            <div class="md:col-span-2 flex md:flex-col md:gap-1 gap-4 items-baseline">
              <span class="mono text-xs text-[color:var(--color-muted)]">{pkg.code}</span>
              <span class="mono text-xs text-[color:var(--color-muted)] md:mt-auto">{pkg.delivery}</span>
            </div>
            <div class="md:col-span-7">
              <h2 class="text-lg font-semibold text-[color:var(--color-fg-strong)] tracking-tight">
                {pkg.name}
              </h2>
              <p class="mt-2 text-[color:var(--color-muted)] leading-relaxed">
                {pkg.summary}
              </p>
            </div>
            <div class="md:col-span-3 md:text-right flex md:block items-center justify-between gap-4">
              <span class="mono text-base text-[color:var(--color-fg-strong)] block">
                {formatGBP(pkg.price)}{pkg.priceSuffix ?? ""}
              </span>
              <span class="mono text-xs text-[color:var(--color-muted)] group-hover:text-[color:var(--color-accent)] transition-colors mt-2 inline-block">
                view spec →
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="container-page pb-24">
    <div class="border border-[color:var(--color-rule)] p-8 grid gap-6 md:grid-cols-12 items-center">
      <div class="md:col-span-8">
        <Annotation label="pricing notes" />
        <p class="mt-3 text-[color:var(--color-fg)] leading-relaxed">
          All prices in GBP, exclusive of VAT. Payment terms are 50% on signature and 50% on delivery for fixed-scope packages. Retainers are billed monthly in advance. Pre-revenue startups receive 20% off their first package.
        </p>
      </div>
      <div class="md:col-span-4 md:text-right">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-4 py-2.5 border border-[color:var(--color-rule)] hover:border-[color:var(--color-accent)] mono text-sm transition-colors"
        >
          Discuss a fit →
        </a>
      </div>
    </div>
  </section>
</Page>

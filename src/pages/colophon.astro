---
import Page from "~/layouts/Page.astro";
import Annotation from "~/components/Annotation.astro";
import { BUILD } from "~/consts";

const buildIso = new Date().toISOString();
---

<Page
  title="Colophon"
  description="The stack, performance budget, accessibility commitments and hosting that power blueslabvelocity.com. We dogfood Azure Static Web Apps."
  path="/colophon"
>
  <section class="container-page pt-10 sm:pt-16 pb-10 sm:pb-12 border-b border-[color:var(--color-rule)]">
    <Annotation label="// colophon" />
    <h1 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] leading-[1.1] md:leading-[1.05] max-w-3xl text-balance">
      How this site is built
    </h1>
    <p class="mt-5 text-base sm:text-lg text-[color:var(--color-fg)] max-w-2xl leading-relaxed text-pretty">
      We dogfood Azure Static Web Apps. The stack here is the same shape we recommend to clients shipping marketing sites: small, static, fast, no third-party JavaScript.
    </p>
  </section>

  <section class="container-page py-14 grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <Annotation label="// stack" />
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]">
        Stack
      </h2>
    </div>
    <div class="lg:col-span-8">
      <dl class="border border-[color:var(--color-rule)] divide-y divide-[color:var(--color-rule)]">
        {[
          ["Framework", "Astro 5 with content collections (Zod schemas)"],
          ["Styling", "Tailwind CSS v4, CSS-first config via @theme"],
          ["Language", "TypeScript, strict mode, no any"],
          ["Routing", "Static, View Transitions enabled site-wide"],
          ["Fonts", "Inter Variable and JetBrains Mono Variable, self-hosted, latin subset, size-adjust descriptors tuned to the system fallback"],
          ["Images", "AVIF with WebP fallback via astro:assets"],
          ["Hosting", "Azure Static Web Apps (Standard tier)"],
          ["CI/CD", "GitHub Actions, deploy on push to main"],
          ["Headers", "Strict CSP, HSTS, COOP, no third-party origins allowed"],
          ["Analytics", "None in v1. See below."],
        ].map(([k, v]) => (
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 px-4 sm:px-5 py-3">
            <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)] sm:pt-1">{k}</dt>
            <dd class="sm:col-span-2 text-[color:var(--color-fg)]">{v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="container-page py-14 border-t border-[color:var(--color-rule)] grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <Annotation label="// performance budget" />
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]">
        Performance budget
      </h2>
      <p class="mt-3 text-[color:var(--color-muted)]">
        We hold ourselves to the same numbers we ask of client production sites.
      </p>
    </div>
    <div class="lg:col-span-8">
      <ul class="border border-[color:var(--color-rule)] divide-y divide-[color:var(--color-rule)]">
        {[
          ["LCP (4G throttle)", "< 1.0 s"],
          ["CLS", "0"],
          ["INP", "< 200 ms"],
          ["JS shipped on static routes", "< 5 KB compressed"],
          ["Homepage first-load weight", "< 80 KB compressed"],
          ["Lighthouse on cold deploy", "100 / 100 / 100 / 100"],
        ].map(([k, v]) => (
          <li class="px-4 sm:px-5 py-3 flex items-baseline justify-between gap-4">
            <span class="text-[color:var(--color-fg)]">{k}</span>
            <span class="mono text-sm text-[color:var(--color-fg-strong)]">{v}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="container-page py-14 border-t border-[color:var(--color-rule)] grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <Annotation label="// accessibility" />
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]">
        Accessibility commitments
      </h2>
    </div>
    <div class="lg:col-span-8 space-y-4 text-[color:var(--color-fg)] leading-relaxed">
      <p>
        WCAG 2.2 AA across every route. Colour pairs are checked against APCA and WCAG. Focus states are visible and consistent. The site works with keyboard, screen reader and reduced-motion settings.
      </p>
      <p>
        If you find an accessibility issue, email us. It is treated as a bug, not a feature request.
      </p>
    </div>
  </section>

  <section class="container-page py-14 border-t border-[color:var(--color-rule)] grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <Annotation label="// no analytics" />
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]">
        No analytics in v1
      </h2>
    </div>
    <div class="lg:col-span-8 space-y-4 text-[color:var(--color-fg)] leading-relaxed">
      <p>
        There is no Google Analytics, no Plausible, no Fathom and no Cloudflare Insights running on this site. The only signal we read is whether discovery calls are getting booked. Nothing else changes the work.
      </p>
      <p>
        If we add measurement later, it will be first-party and explicitly named here.
      </p>
    </div>
  </section>

  <section class="container-page py-14 border-t border-[color:var(--color-rule)]">
    <dl class="grid grid-cols-2 md:grid-cols-4 border border-[color:var(--color-rule)] divide-x divide-[color:var(--color-rule)]">
      <div class="px-4 md:px-5 py-4">
        <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Version</dt>
        <dd class="mono mt-2 text-[color:var(--color-fg-strong)]">v{BUILD.version}</dd>
      </div>
      <div class="px-4 md:px-5 py-4">
        <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Build</dt>
        <dd class="mono mt-2 text-[color:var(--color-fg-strong)]">{BUILD.id}</dd>
      </div>
      <div class="px-4 md:px-5 py-4">
        <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Commit</dt>
        <dd class="mono mt-2 text-[color:var(--color-fg-strong)]">{BUILD.commit}</dd>
      </div>
      <div class="px-4 md:px-5 py-4">
        <dt class="mono text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Deployed</dt>
        <dd class="mono mt-2 text-[color:var(--color-fg-strong)]">{buildIso.slice(0, 10)}</dd>
      </div>
    </dl>
  </section>
</Page>

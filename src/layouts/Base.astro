---
import "~/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE } from "~/consts";
import { canonical, organisationJsonLd } from "~/lib/seo";

interface Props {
  title: string;
  description: string;
  path: string;
  type?: "website" | "article";
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  path,
  type = "website",
  publishedTime,
  noindex = false,
} = Astro.props;

const pageTitle = title === SITE.name ? title : `${title} — ${SITE.name}`;
const url = canonical(path);
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark light" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <link rel="icon" href="/bsv-logo-favicon.png" type="image/png" sizes="64x64" />
    <link rel="apple-touch-icon" href="/bsv-logo-favicon.png" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:locale" content="en_GB" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <script src="/theme-bootstrap.js" is:inline></script>
    <script src="/utc-clock.js" defer is:inline></script>

    <ClientRouter />

    <script type="application/ld+json" set:html={organisationJsonLd()} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
